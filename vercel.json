{
  "functions": {
    "src/app/api/**/*.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/auto-populate-order",
      "schedule": "0 13 * * *"
    }
  ],
  "installCommand": "npm install --legacy-peer-deps",
  "build": {
    "env": {
      "NEXT_TELEMETRY_DISABLED": "1",
      "PUPPETEER_SKIP_DOWNLOAD": "true",
      "PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD": "1"
    }
  }
}
