# Database (Neon PostgreSQL)
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# AWS - for SQS simulate-transaction endpoint
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Clerk Authentication
# Get these from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# Browser Service Configuration
# Options: 'puppeteer' (default), 'browserbase'
BROWSER_SERVICE=puppeteer

# Maximum browser instances in pool (Puppeteer only)
MAX_BROWSER_INSTANCES=3

# Browserbase Configuration (only needed if BROWSER_SERVICE=browserbase)
# Sign up at https://browserbase.com
BROWSERBASE_API_KEY=bb_live_...
BROWSERBASE_PROJECT_ID=your_project_id

# Enable residential proxies (requires Developer plan or higher)
# NOTE: Proxies actually INCREASE bot detection for Sam's Club - keep disabled
BROWSERBASE_ENABLE_PROXIES=false

# ScraperAPI Configuration (optional)
# Sign up at https://www.scraperapi.com
SCRAPERAPI_KEY=your_scraperapi_key

# ScrapingBee Configuration (optional)
# Sign up at https://www.scrapingbee.com
SCRAPINGBEE_API_KEY=your_scrapingbee_key
